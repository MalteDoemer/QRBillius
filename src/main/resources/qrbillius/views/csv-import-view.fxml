<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="qrbillius.views.CsvImportView">
    <top>
        <Label styleClass="header-label" text="%importViewHeader" BorderPane.alignment="TOP_LEFT">
            <BorderPane.margin>
                <Insets bottom="10.0" left="20.0" right="20.0" top="10.0"/>
            </BorderPane.margin>
        </Label>
    </top>

    <center>
        <ScrollPane>
            <VBox spacing="10.0">
                <VBox spacing="5.0">
                    <Label text="%csvSeparatorField"/>
                    <TextField fx:id="csvSeparatorField"/>
                </VBox>
                <VBox spacing="5.0">
                    <Label text="%csvNameFormatField"/>
                    <TextField fx:id="csvNameFormatField"/>
                </VBox>
                <VBox spacing="5.0">
                    <Label text="%csvAddressLine1FormatField"/>
                    <TextField fx:id="csvAddressLine1FormatField"/>
                </VBox>
                <VBox spacing="5.0">
                    <Label text="%csvAddressLine2FormatField"/>
                    <TextField fx:id="csvAddressLine2FormatField"/>
                </VBox>
                <VBox spacing="5.0">
                    <Label text="%csvPaymentAmountFormatField"/>
                    <TextField fx:id="csvPaymentAmountFormatField"/>
                </VBox>
                <VBox spacing="5.0">
                    <Label text="%csvAdditionalInfoFormatField"/>
                    <TextField fx:id="csvAdditionalInfoFormatField"/>
                </VBox>
                <padding>
                    <Insets bottom="10.0" left="20.0" right="20.0" top="10.0"/>
                </padding>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10.0" BorderPane.alignment="CENTER">
            <children>
                <Button alignment="CENTER" mnemonicParsing="false" onAction="#onImportButtonClick" prefWidth="120.0"
                        text="%importButton"/>
                <Button alignment="CENTER" mnemonicParsing="false" onAction="#onCancelButtonClick" prefWidth="120.0"
                        text="%cancelButton"/>
            </children>
            <padding>
                <Insets bottom="10.0" left="20.0" right="20.0" top="10.0"/>
            </padding>
        </HBox>
    </bottom>
</BorderPane>
